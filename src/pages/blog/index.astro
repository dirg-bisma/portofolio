---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { ui } from '../../utils/i18n';

const lang = 'en';
const t = ui[lang];

const posts = await getCollection('blog', ({ data }) => !data.draft && data.lang === lang);
const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = [...new Set(posts.map(p => p.data.category))].sort();
---

<BaseLayout
  lang={lang}
  title="Blog"
  description="Technical articles on ERP architecture, IoT systems, Golang backend design, and AI automation by Dirga."
>
  <Navbar slot="nav" />

  <div class="container-custom section-padding">
    <!-- Header -->
    <div class="mb-12">
      <p class="text-xs font-mono text-[#8A9BA8] uppercase tracking-widest mb-2">Writing</p>
      <h1 class="text-4xl font-bold text-[#1B3C53] mb-4">Blog</h1>
      <p class="text-[#8A9BA8] max-w-2xl">
        Technical deep-dives on systems thinking, architecture patterns, and the engineering behind real products.
      </p>
    </div>

    <!-- Category filter -->
    {categories.length > 1 && (
      <div class="flex flex-wrap gap-2 mb-8">
        <span class="text-xs font-mono text-[#8A9BA8] self-center mr-2">Topics:</span>
        {categories.map(cat => (
          <span class="text-xs px-3 py-1 rounded-full border border-[#E4DDD8] text-[#456882] capitalize cursor-default hover:border-[#456882] transition-colors">
            {cat}
          </span>
        ))}
      </div>
    )}

    <!-- Posts grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {sorted.map(post => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          category={post.data.category}
          slug={post.id}
        />
      ))}
    </div>

    {sorted.length === 0 && (
      <div class="text-center py-20 text-[#8A9BA8]">
        <p class="text-lg">No articles yet — coming soon.</p>
      </div>
    )}
  </div>

  <Footer slot="footer" />
</BaseLayout>
