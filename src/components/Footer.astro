---
import { Icon } from 'astro-icon/components';
import { ui } from '../utils/i18n';

const currentPath = Astro.url.pathname;
const lang = currentPath.startsWith('/id') ? 'id' : 'en';
const t = ui[lang];

const year = new Date().getFullYear();
const links = [
  { href: lang === 'en' ? '/projects' : '/id/projects', label: t['nav.projects'] },
  { href: lang === 'en' ? '/case-studies' : '/id/case-studies', label: t['nav.caseStudies'] },
  { href: lang === 'en' ? '/blog' : '/id/blog', label: t['nav.blog'] },
  { href: lang === 'en' ? '/about' : '/id/about', label: t['nav.about'] },
  { href: lang === 'en' ? '/contact' : '/id/contact', label: t['nav.contact'] },
];
const socials = [
  {
    href: 'https://github.com/dirkaST',
    label: 'GitHub',
    iconName: 'material-symbols-light:code-blocks-outline-rounded',
  },
  {
    href: 'https://linkedin.com/in/dirga',
    label: 'LinkedIn',
    iconName: 'material-symbols-light:badge-outline-rounded',
  },
];
---

<footer class="border-t border-[#E4DDD8] bg-[#F9F3EF] mt-auto">
  <div class="container-custom py-10">
    <div class="flex flex-col md:flex-row justify-between gap-8">
      <!-- Brand -->
      <div class="max-w-xs">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-7 h-7 rounded-md bg-[#1B3C53] flex items-center justify-center text-white font-mono font-bold text-xs">
            D/
          </div>
          <span class="font-semibold text-[#1B3C53] tracking-tight">Dirga</span>
        </div>
        <p class="text-sm text-[#8A9BA8] leading-relaxed">
          {t['footer.description']}
        </p>
      </div>

      <!-- Nav links -->
      <div>
        <p class="text-xs font-semibold text-[#8A9BA8] uppercase tracking-wider mb-3">{t['footer.navigation']}</p>
        <ul class="flex flex-col gap-2">
          {links.map(l => (
            <li>
              <a href={l.href} class="text-sm text-[#456882] hover:text-[#1B3C53] transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Socials -->
      <div>
        <p class="text-xs font-semibold text-[#8A9BA8] uppercase tracking-wider mb-3">{t['footer.connect']}</p>
        <div class="flex flex-col gap-2">
          {socials.map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-[#456882] hover:text-[#1B3C53] transition-colors flex items-center gap-1.5"
            >
              <Icon name={s.iconName} class="w-4 h-4" />
              {s.label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 pt-6 border-t border-[#E4DDD8] flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-xs text-[#8A9BA8]">
        &copy; {year} Dirga · Sinergi Teknokarya. {t['footer.rights']}
      </p>
      <p class="text-xs text-[#8A9BA8]">
        {t['footer.builtWith']} <a href="https://astro.build" target="_blank" rel="noopener" class="hover:text-[#1B3C53] transition-colors">Astro</a>
        &amp; <a href="https://tailwindcss.com" target="_blank" rel="noopener" class="hover:text-[#1B3C53] transition-colors">Tailwind</a>
      </p>
    </div>
  </div>
</footer>
